# Foundry VTT Configuration
# Copy this file to .env and fill in your values
# DO NOT commit your actual credentials to version control

# Foundry VTT Credentials
FOUNDRY_USERNAME=your-foundry-username
FOUNDRY_PASSWORD=your-foundry-password
FOUNDRY_ADMIN_KEY=your-admin-key

# Foundry Version (release, 13, 14, etc.)
FOUNDRY_IMAGE_TAG=release

# External Port Configuration
FOUNDRY_EXTERNAL_PORT=30000
