{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://fitd.ttk.investigators/schemas/class.schema.json",
  "title": "TTK investigator class source",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "img", "description", "experience_clues", "base_skills"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "img": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "description": "Author as plain text or markdown. Do not store Foundry HTML."
    },
    "experience_clues": {
      "type": "string",
      "description": "Author as plain text or markdown. Do not store Foundry HTML."
    },
    "base_skills": {
      "oneOf": [{ "$ref": "#/$defs/bitdBaseSkills" }, { "$ref": "#/$defs/ttkBaseSkills" }]
    },
    "acquaintances_label": {
      "type": "string",
      "description": "BitD i18n key or literal label, depending on downstream use."
    },
    "tags": {
      "$ref": "#/$defs/tags"
    }
  },
  "$defs": {
    "actionRating": {
      "type": "integer",
      "minimum": 0,
      "maximum": 4
    },
    "bitdBaseSkills": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hunt",
        "study",
        "survey",
        "tinker",
        "finesse",
        "prowl",
        "skirmish",
        "wreck",
        "attune",
        "command",
        "consort",
        "sway"
      ],
      "properties": {
        "hunt": { "$ref": "#/$defs/actionRating" },
        "study": { "$ref": "#/$defs/actionRating" },
        "survey": { "$ref": "#/$defs/actionRating" },
        "tinker": { "$ref": "#/$defs/actionRating" },
        "finesse": { "$ref": "#/$defs/actionRating" },
        "prowl": { "$ref": "#/$defs/actionRating" },
        "skirmish": { "$ref": "#/$defs/actionRating" },
        "wreck": { "$ref": "#/$defs/actionRating" },
        "attune": { "$ref": "#/$defs/actionRating" },
        "command": { "$ref": "#/$defs/actionRating" },
        "consort": { "$ref": "#/$defs/actionRating" },
        "sway": { "$ref": "#/$defs/actionRating" }
      }
    },
    "ttkBaseSkills": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assault",
        "fabricate",
        "finesse",
        "maneuver",
        "esoteric",
        "medical",
        "research",
        "tradecraft",
        "bureaucracy",
        "influence",
        "network",
        "streetwise"
      ],
      "properties": {
        "assault": { "$ref": "#/$defs/actionRating" },
        "fabricate": { "$ref": "#/$defs/actionRating" },
        "finesse": { "$ref": "#/$defs/actionRating" },
        "maneuver": { "$ref": "#/$defs/actionRating" },
        "esoteric": { "$ref": "#/$defs/actionRating" },
        "medical": { "$ref": "#/$defs/actionRating" },
        "research": { "$ref": "#/$defs/actionRating" },
        "tradecraft": { "$ref": "#/$defs/actionRating" },
        "bureaucracy": { "$ref": "#/$defs/actionRating" },
        "influence": { "$ref": "#/$defs/actionRating" },
        "network": { "$ref": "#/$defs/actionRating" },
        "streetwise": { "$ref": "#/$defs/actionRating" }
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:[_-][a-z0-9]+)*$"
      },
      "uniqueItems": true
    }
  }
}
