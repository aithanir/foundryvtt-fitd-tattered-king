{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://fitd.ttk.investigators/schemas/ability.schema.json",
  "title": "TTK investigator ability source",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "class", "name", "description"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "class": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "img": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "description": "Author as plain text or markdown. Do not store Foundry HTML."
    },
    "price": {
      "type": "integer",
      "minimum": 0,
      "default": 1
    },
    "class_default": {
      "type": "boolean",
      "default": false
    },
    "tags": {
      "$ref": "#/$defs/tags"
    },
    "automation": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/automation"
      },
      "default": []
    },
    "effects": {
      "type": "array",
      "default": []
    },
    "flags": {
      "type": "object",
      "default": {}
    }
  },
  "$defs": {
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:[_-][a-z0-9]+)*$"
      },
      "uniqueItems": true
    },
    "automation": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "slot": {
          "type": "string",
          "minLength": 1
        },
        "triggers": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": true
    }
  }
}
