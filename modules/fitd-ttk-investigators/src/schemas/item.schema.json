{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://fitd.ttk.investigators/schemas/item.schema.json",
  "title": "TTK investigator item source",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "description", "load"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "img": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "load": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9
    },
    "uses": {
      "type": "integer",
      "minimum": 0,
      "default": 1
    },
    "class": {
      "type": "string",
      "default": ""
    },
    "additional_info": {
      "type": "string",
      "default": ""
    },
    "num_available": {
      "type": "integer",
      "minimum": 0,
      "default": 1
    },
    "tags": {
      "$ref": "#/$defs/tags"
    }
  },
  "$defs": {
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:[_-][a-z0-9]+)*$"
      },
      "uniqueItems": true
    }
  }
}
