{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for the evidence"
    },
    "type": {
      "type": "string",
      "enum": ["physical", "digital", "testimonial"],
      "description": "Type of evidence"
    },
    "description": {
      "type": "string",
      "description": "Description of the evidence"
    },
    "location": {
      "type": "string",
      "description": "Where the evidence was found or stored"
    },
    "collectedBy": {
      "type": "string",
      "description": "Who collected the evidence"
    }
  },
  "required": ["id", "type", "description"]
}