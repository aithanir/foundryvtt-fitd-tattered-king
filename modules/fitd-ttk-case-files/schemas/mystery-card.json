{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fitd.ttk.case-files/schemas/mystery-card.json",
  "title": "Mystery Card",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "title", "type", "revelation"],
  "properties": {
    "id": {
      "$ref": "https://fitd.ttk.case-files/schemas/mystery-common.json#/$defs/id"
    },
    "title": {
      "type": "string"
    },
    "type": {
      "$ref": "https://fitd.ttk.case-files/schemas/mystery-common.json#/$defs/frameType",
      "description": "Usually matches the Frame it fills. Blank Frames may accept multiple types."
    },
    "revelation": {
      "type": "string",
      "description": "The heavy structural truth this card reveals."
    },
    "occult": {
      "type": "boolean",
      "default": false
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "gmNotes": {
      "type": "string",
      "default": ""
    },
    "revealed": {
      "type": "boolean",
      "default": false
    }
  }
}
